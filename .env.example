# IntelliRate Setup - Copy this to your .env file and fill in values

# CRITICAL: Get your Groq API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_ACTUAL_GROQ_API_KEY_HERE

# Database Configuration (Neon.tech - free PostgreSQL)
# Get your connection string from https://neon.tech → your project → Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Redis Configuration (Upstash - free tier)
# Get your URL from https://upstash.com → your database → Details
REDIS_URL=rediss://default:PASSWORD@xxxx.upstash.io:6380

# App Configuration
APP_NAME=IntelliRate Gateway
APP_VERSION=1.0.0
DEBUG=True

# CORS Origins
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Optional: AWS/Firebase configs
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# FIREBASE_CREDENTIALS_PATH=
